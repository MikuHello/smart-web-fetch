#!/bin/bash

set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

TIMEOUT=30
JINA_MIN_LENGTH=100
MARKDOWN_NEW_MIN_LENGTH=40
DEFUDDLE_MIN_LENGTH=40

JINA_READER_BASE="https://r.jina.ai"
MARKDOWN_NEW="https://api.markdown.new/api/v1/convert"
DEFUDDLE_MD="https://defuddle.md/api/convert"

show_help() {
    cat <<'EOF'
Smart Web Fetch - lightweight web-to-Markdown fetcher

Usage:
    smart-web-fetch <URL> [options]

Options:
    -h, --help          Show help
    -o, --output FILE   Write output to file
    -s, --service NAME  Force service: jina|markdown|defuddle
    -v, --verbose       Show verbose logs
    --no-clean          Skip HTML cleanup in the basic curl fallback

Examples:
    smart-web-fetch https://example.com
    smart-web-fetch https://example.com -o output.md
    smart-web-fetch https://example.com -s jina
    smart-web-fetch https://example.com --no-clean

Fallback order:
    1. Jina Reader
    2. markdown.new
    3. defuddle.md
    4. direct curl fallback
EOF
}

log_info() {
    [[ "$VERBOSE" == "1" ]] && echo -e "${BLUE}[INFO]${NC} $1" >&2
}

log_success() {
    [[ "$VERBOSE" == "1" ]] && echo -e "${GREEN}[SUCCESS]${NC} $1" >&2
}

log_warn() {
    [[ "$VERBOSE" == "1" ]] && echo -e "${YELLOW}[WARN]${NC} $1" >&2
}

log_error() {
    echo -e "${RED}[ERROR]${NC} $1" >&2
}

build_jina_url() {
    local target_url="$1"
    local scheme="http"
    local url_without_scheme="$target_url"

    if [[ "$target_url" =~ ^(https?)://(.*)$ ]]; then
        scheme="${BASH_REMATCH[1]}"
        url_without_scheme="${BASH_REMATCH[2]}"
    fi

    printf '%s/%s://%s\n' "$JINA_READER_BASE" "$scheme" "$url_without_scheme"
}

is_structured_error_response() {
    local response="$1"
    local compact_response
    local lowered_response

    if command -v jq >/dev/null 2>&1; then
        if printf '%s' "$response" | jq -e '
            if type == "object" then
                .error as $error
                | .message as $message
                | (
                    ($error != null and (
                        ($error | type == "boolean" and $error == true)
                        or ($error | type == "string" and ($error | test("(?i)error|fail|invalid|unauthorized|forbidden|not found")))
                    ))
                    or
                    ($message != null and ($message | type == "string" and ($message | test("(?i)error|fail|invalid|unauthorized|forbidden|not found"))))
                )
            else
                false
            end
        ' >/dev/null 2>&1; then
            return 0
        fi
    fi

    # Fallback without jq: only treat JSON-looking payloads with explicit
    # "error"/"message" keys and common failure semantics as structured errors.
    compact_response=$(printf '%s' "$response" | tr -d '[:space:]')
    if [[ ! "$compact_response" =~ ^[\{\[] ]]; then
        return 1
    fi

    lowered_response=$(printf '%s' "$compact_response" | tr '[:upper:]' '[:lower:]')

    if [[ "$lowered_response" =~ \"error\":true ]]; then
        return 0
    fi

    if [[ "$lowered_response" =~ \"(error|message)\":\"[^\"]*(error|fail|invalid|unauthorized|forbidden|not[[:space:]_-]?found)[^\"]*\" ]]; then
        return 0
    fi

    return 1
}

clean_html() {
    if command -v perl >/dev/null 2>&1; then
        perl -0pe 's{<script\b[^>]*>.*?</script>}{}gsi; s{<style\b[^>]*>.*?</style>}{}gsi; s{<noscript\b[^>]*>.*?</noscript>}{}gsi; s{<nav\b[^>]*>.*?</nav>}{}gsi; s{<header\b[^>]*>.*?</header>}{}gsi; s{<footer\b[^>]*>.*?</footer>}{}gsi; s{<aside\b[^>]*>.*?</aside>}{}gsi; s{<!--.*?-->}{}gsi; s{\s(?:class|id|style|on\w+)=("[^"]*"|'"'"'[^'"'"']*'"'"')}{}gsi;'
    else
        sed \
            -e 's/class="[^"]*"//g' \
            -e 's/id="[^"]*"//g' \
            -e 's/style="[^"]*"//g' \
            -e 's/on[a-zA-Z0-9_]*="[^"]*"//g'
    fi
}

# Build {"url":"..."} safely for POST bodies.
# Do not directly concatenate JSON like "{\"url\":\"$url\"}" because URLs can contain
# quotes, backslashes, or control characters that would break JSON syntax or change payload meaning.
build_url_json_payload() {
    local url="$1"
    local escaped_url=""

    if command -v jq >/dev/null 2>&1; then
        jq -n --arg url "$url" '{url:$url}'
        return 0
    fi

    escaped_url=$(json_escape_minimal "$url")
    printf '{"url":"%s"}' "$escaped_url"
}

json_escape_minimal() {
    local input="$1"
    local output=""
    local char=""
    local byte=""
    local hex=""
    local i=0

    for (( i=0; i<${#input}; i++ )); do
        char="${input:i:1}"
        case "$char" in
            \\) output+='\\\\' ;;
            '"') output+='\\"' ;;
            $'\b') output+='\\b' ;;
            $'\f') output+='\\f' ;;
            $'\n') output+='\\n' ;;
            $'\r') output+='\\r' ;;
            $'\t') output+='\\t' ;;
            *)
                byte=$(printf '%s' "$char" | od -An -tu1 | tr -d '[:space:]')
                if [[ -n "$byte" ]] && (( byte < 32 )); then
                    printf -v hex '%02X' "$byte"
                    output+="\\u00$hex"
                else
                    output+="$char"
                fi
                ;;
        esac
    done

    printf '%s' "$output"
}

fetch_jina() {
    local url="$1"
    local response
    local http_code

    log_info "Trying Jina Reader"

    local jina_url
    jina_url=$(build_jina_url "$url")

    # 判定策略：仅将 HTTP 非 2xx、结构化错误字段、空/过短响应视为失败，不再按全文关键词匹配。
    if ! response=$(curl -sL --max-time "$TIMEOUT" \
        -H "User-Agent: SmartWebFetch/1.0" \
        -w $'\n%{http_code}' \
        "$jina_url" 2>&1); then
        log_warn "Jina Reader request failed"
        return 1
    fi
    http_code="${response##*$'\n'}"
    response="${response%$'\n'*}"

    if [[ ! "$http_code" =~ ^2[0-9][0-9]$ ]]; then
        log_warn "Jina Reader returned HTTP ${http_code:-unknown}"
        return 1
    fi

    if is_structured_error_response "$response"; then
        log_warn "Jina Reader returned structured error payload"
        return 1
    fi

    if [[ -z "$response" ]] || [[ ${#response} -lt "$JINA_MIN_LENGTH" ]]; then
        log_warn "Jina Reader returned empty or too-short content"
        return 1
    fi

    log_success "Jina Reader succeeded"
    printf '%s\n' "$response"
}

fetch_markdown_new() {
    local url="$1"
    local response
    local http_code
    local markdown=""
    local payload=""

    log_info "Trying markdown.new"
    payload=$(build_url_json_payload "$url")

    # 判定策略：仅将 HTTP 非 2xx、结构化错误字段、空/过短响应视为失败，不再按全文关键词匹配。
    if ! response=$(curl -sL --max-time "$TIMEOUT" \
        -X POST \
        -H "Content-Type: application/json" \
        -H "User-Agent: SmartWebFetch/1.0" \
        -d "$payload" \
        -w $'\n%{http_code}' \
        "$MARKDOWN_NEW" 2>&1); then
        log_warn "markdown.new request failed"
        return 1
    fi
    http_code="${response##*$'\n'}"
    response="${response%$'\n'*}"

    if [[ ! "$http_code" =~ ^2[0-9][0-9]$ ]]; then
        log_warn "markdown.new returned HTTP ${http_code:-unknown}"
        return 1
    fi

    if is_structured_error_response "$response"; then
        log_warn "markdown.new returned structured error payload"
        return 1
    fi

    if [[ -z "$response" ]] || [[ ${#response} -lt "$MARKDOWN_NEW_MIN_LENGTH" ]]; then
        log_warn "markdown.new returned empty or too-short content"
        return 1
    fi

    if command -v jq >/dev/null 2>&1; then
        markdown=$(printf '%s' "$response" | jq -r '.markdown // .content // .data // empty' 2>/dev/null || true)
    fi

    log_success "markdown.new succeeded"

    if [[ -n "$markdown" ]] && [[ "$markdown" != "null" ]]; then
        printf '%s\n' "$markdown"
    else
        printf '%s\n' "$response"
    fi
}

fetch_defuddle() {
    local url="$1"
    local response
    local payload=""
    local http_code

    log_info "Trying defuddle.md"
    payload=$(build_url_json_payload "$url")

    # 判定策略：仅将 HTTP 非 2xx、结构化错误字段、空/过短响应视为失败，不再按全文关键词匹配。
    if ! response=$(curl -sL --max-time "$TIMEOUT" \
        -X POST \
        -H "Content-Type: application/json" \
        -H "User-Agent: SmartWebFetch/1.0" \
        -d "$payload" \
        -w $'\n%{http_code}' \
        "$DEFUDDLE_MD" 2>&1); then
        log_warn "defuddle.md request failed"
        return 1
    fi
    http_code="${response##*$'\n'}"
    response="${response%$'\n'*}"

    if [[ ! "$http_code" =~ ^2[0-9][0-9]$ ]]; then
        log_warn "defuddle.md returned HTTP ${http_code:-unknown}"
        return 1
    fi

    if is_structured_error_response "$response"; then
        log_warn "defuddle.md returned structured error payload"
        return 1
    fi

    if [[ -z "$response" ]] || [[ ${#response} -lt "$DEFUDDLE_MIN_LENGTH" ]]; then
        log_warn "defuddle.md returned empty or too-short content"
        return 1
    fi

    log_success "defuddle.md succeeded"
    printf '%s\n' "$response"
}

fetch_basic() {
    local url="$1"
    local response
    local processed_response

    log_info "Trying direct curl fallback"

    if ! response=$(curl -sL --max-time "$TIMEOUT" \
        -H "User-Agent: Mozilla/5.0" \
        -H "Accept: text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8" \
        "$url" 2>&1); then
        log_warn "Direct curl fallback failed"
        return 1
    fi

    processed_response="$response"

    if [[ "$NO_CLEAN" != "1" ]]; then
        processed_response=$(printf '%s' "$response" | clean_html)
    fi

    if command -v html2text >/dev/null 2>&1; then
        printf '%s' "$processed_response" | html2text -utf8 2>/dev/null || printf '%s\n' "$processed_response"
    elif command -v lynx >/dev/null 2>&1; then
        printf '%s' "$processed_response" | lynx -stdin -dump -nolist 2>/dev/null || printf '%s\n' "$processed_response"
    else
        printf '%s\n' "$processed_response"
    fi

    log_success "Direct curl fallback succeeded"
}

smart_fetch() {
    local url="$1"
    local specified_service="$2"
    local result=""

    if [[ -z "$url" ]]; then
        log_error "Please provide a URL"
        return 1
    fi

    if [[ ! "$url" =~ ^https?:// ]]; then
        url="https://$url"
        log_info "Added https:// prefix: $url"
    fi

    log_info "Fetching $url"

    if [[ -n "$specified_service" ]]; then
        case "$specified_service" in
            jina)
                result=$(fetch_jina "$url") && { printf '%s\n' "$result"; return 0; }
                ;;
            markdown)
                result=$(fetch_markdown_new "$url") && { printf '%s\n' "$result"; return 0; }
                ;;
            defuddle)
                result=$(fetch_defuddle "$url") && { printf '%s\n' "$result"; return 0; }
                ;;
            *)
                log_error "Unknown service: $specified_service"
                return 1
                ;;
        esac
    fi

    result=$(fetch_jina "$url") && { printf '%s\n' "$result"; return 0; }
    result=$(fetch_markdown_new "$url") && { printf '%s\n' "$result"; return 0; }
    result=$(fetch_defuddle "$url") && { printf '%s\n' "$result"; return 0; }
    result=$(fetch_basic "$url") && { printf '%s\n' "$result"; return 0; }

    log_error "All fetch methods failed"
    return 1
}

URL=""
OUTPUT=""
SERVICE=""
VERBOSE="0"
NO_CLEAN="0"

while [[ $# -gt 0 ]]; do
    case "$1" in
        -h|--help)
            show_help
            exit 0
            ;;
        -o|--output)
            if [[ -z "$2" ]]; then
                log_error "Missing value for $1"
                exit 1
            fi
            OUTPUT="$2"
            shift 2
            ;;
        -s|--service)
            if [[ -z "$2" ]]; then
                log_error "Missing value for $1"
                exit 1
            fi
            SERVICE="$2"
            shift 2
            ;;
        -v|--verbose)
            VERBOSE="1"
            shift
            ;;
        --no-clean)
            NO_CLEAN="1"
            shift
            ;;
        -*)
            log_error "Unknown option: $1"
            show_help
            exit 1
            ;;
        *)
            URL="$1"
            shift
            ;;
    esac
done

if [[ -z "$URL" ]]; then
    log_error "Please provide a URL"
    show_help
    exit 1
fi

CONTENT=$(smart_fetch "$URL" "$SERVICE")

if [[ -n "$OUTPUT" ]]; then
    printf '%s\n' "$CONTENT" > "$OUTPUT"
    log_success "Saved output to: $OUTPUT"
else
    printf '%s\n' "$CONTENT"
fi
